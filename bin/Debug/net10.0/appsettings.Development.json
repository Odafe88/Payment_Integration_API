{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "PaymentProviders": {
    "Flutterwave": {
      "BaseUrl": "https://api.flutterwave.com/v3/payments",
      "SecretKey": "FLW_SECRET_KEY",
      "EncryptionKey": "FLW_ENCRYPTION_KEY",
      "WebhookSecret": "FLW_VERIF_HASH"
    },
    "Paystack": {
      "BaseUrl": "https://api.paystack.co",
      "SecretKey": "PAYSTACK_SECRET_KEY",
      "WebhookSecret": "PAYSTACK_WEBHOOK_SECRET"
    },
    "Interswitch": {
      "BaseUrl": "https://qa.interswitchng.com/passport/oauth/token",
      "ClientId": "INTERSWITCH_CLIENT_ID",
      "ClientSecret": "INTERSWITCH_CLIENT_SECRET",
      "WebhookSecret": "INTERSWITCH_WEBHOOK_SECRET"
    }
  }
}
